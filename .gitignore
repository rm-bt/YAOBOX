# ==============================
# YAOBOX repository ignore rules
# ==============================

# Environment / secrets
.env
.env.*
!.env.example
backend/.env
frontend/.env
backend/.env.local
frontend/.env.local

# Python virtual environments
.venv/
.venv-*/
venv/
backend/.venv/

# Python cache / test cache
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node dependencies
node_modules/
frontend/node_modules/

# Frontend build artifacts
/dist/
frontend/dist/
*.tsbuildinfo

# IDE / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Runtime uploads and generated files
backend/uploads/*
!backend/uploads/
!backend/uploads/.gitkeep
uploads/
!backend/uploads/.gitkeep

# Scratch dumps / generated debug files
*_dump.txt
scanner_fix_dump.txt

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Keep uploads directory present without tracking uploaded files
!backend/uploads/
!backend/uploads/.gitkeep
